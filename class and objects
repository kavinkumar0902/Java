class Car{
    int carNo;
    String carName;
    String carColor;
    int noOfSeats;
   public Car(int carNo, String carName, String carColor, int noOfSeats){
        this.carNo = carNo;
        this.carName = carName;
        this.carColor = carColor;
        this.noOfSeats = noOfSeats;
        
    }
}
class classObjects {
    public static void main(String[] args) {
        Car c1 = new Car(1992,"Suzuki","Black",5);
        System.out.println(c1.carNo);
        System.out.println(c1.carName);
        System.out.println(c1.carColor);
        System.out.println(c1.noOfSeats);
        
    }
}
